<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/spacing_md"
    android:background="@drawable/bg_card_white"
    android:orientation="vertical"
    android:padding="@dimen/spacing_base">

    <!-- Top Row: Mode + Session Type -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tv_hist_mode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_chip_teal"
            android:paddingHorizontal="@dimen/spacing_sm"
            android:paddingVertical="3dp"
            android:gravity="center"
            android:includeFontPadding="false"
            android:textColor="@android:color/white"
            android:textSize="@dimen/text_label"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_hist_session_type"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_sm"
            android:textColor="@color/color_text_secondary"
            android:textSize="@dimen/text_caption" />

    </LinearLayout>

    <!-- Second Row: Status + Date -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_xs"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tv_hist_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_chip_green"
            android:paddingHorizontal="@dimen/spacing_sm"
            android:paddingVertical="3dp"
            android:gravity="center"
            android:includeFontPadding="false"
            android:textColor="@android:color/white"
            android:textSize="@dimen/text_label"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_hist_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_sm"
            android:textColor="@color/color_text_secondary"
            android:textSize="@dimen/text_caption" />

    </LinearLayout>

    <!-- Stats Row (2x2 Grid) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_md"
        android:orientation="vertical">

        <!-- Row 1: Score & Accuracy -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <!-- Score -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/history_item_score_label"
                    android:includeFontPadding="false"
                    android:textColor="@color/color_text_secondary"
                    android:textSize="@dimen/text_label" />

                <TextView
                    android:id="@+id/tv_hist_score"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:includeFontPadding="false"
                    android:textColor="@color/color_text_primary"
                    android:textSize="@dimen/text_body"
                    android:textStyle="bold" />

            </LinearLayout>

            <!-- Accuracy -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/history_item_accuracy_label"
                    android:includeFontPadding="false"
                    android:textColor="@color/color_text_secondary"
                    android:textSize="@dimen/text_label" />

                <TextView
                    android:id="@+id/tv_hist_item_accuracy"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:includeFontPadding="false"
                    android:textColor="@color/color_text_primary"
                    android:textSize="@dimen/text_body"
                    android:textStyle="bold" />

            </LinearLayout>

        </LinearLayout>

        <!-- Row 2: Avg Time & Rating -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_sm"
            android:orientation="horizontal">

            <!-- Avg Time -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/history_item_avg_time_label"
                    android:includeFontPadding="false"
                    android:textColor="@color/color_text_secondary"
                    android:textSize="@dimen/text_label" />

                <TextView
                    android:id="@+id/tv_hist_avg_time"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:includeFontPadding="false"
                    android:textColor="@color/color_text_primary"
                    android:textSize="@dimen/text_body"
                    android:textStyle="bold" />

            </LinearLayout>

            <!-- Rating -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/history_item_rating_label"
                    android:includeFontPadding="false"
                    android:textColor="@color/color_text_secondary"
                    android:textSize="@dimen/text_label" />

                <TextView
                    android:id="@+id/tv_hist_rating"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:includeFontPadding="false"
                    android:textColor="@color/color_text_primary"
                    android:textSize="@dimen/text_body"
                    android:textStyle="bold" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <!-- Badges Row -->
    <LinearLayout
        android:id="@+id/layout_badges"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_md"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tv_hist_achievement1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_chip_green"
            android:paddingHorizontal="@dimen/spacing_sm"
            android:paddingVertical="@dimen/spacing_xs"
            android:textColor="@android:color/white"
            android:textSize="@dimen/text_label"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tv_hist_achievement2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_xs"
            android:background="@drawable/bg_chip_green"
            android:paddingHorizontal="@dimen/spacing_sm"
            android:paddingVertical="@dimen/spacing_xs"
            android:textColor="@android:color/white"
            android:textSize="@dimen/text_label"
            android:visibility="gone" />

    </LinearLayout>

    <!-- View Result Button -->
    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btn_view_result"
        android:layout_width="match_parent"
        android:layout_height="@dimen/button_height"
        android:layout_marginTop="@dimen/spacing_md"
        android:background="@drawable/bg_button_outline"
        android:text="@string/view_result"
        android:gravity="center"
        android:includeFontPadding="false"
        android:textColor="@color/color_text_primary"
        android:textSize="@dimen/text_label"
        android:textStyle="bold" />

</LinearLayout>
