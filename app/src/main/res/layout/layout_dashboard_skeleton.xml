<?xml version="1.0" encoding="utf-8"?>
<com.facebook.shimmer.ShimmerFrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/shimmer_dashboard"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    app:shimmer_auto_start="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_base">

        <!-- Header Card Skeleton -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card_white"
            android:orientation="vertical"
            android:padding="@dimen/spacing_base">

            <!-- Title -->
            <View
                android:layout_width="100dp"
                android:layout_height="16dp"
                android:background="@drawable/bg_skeleton" />

            <!-- Rating -->
            <View
                android:layout_width="120dp"
                android:layout_height="48dp"
                android:layout_marginTop="@dimen/spacing_xs"
                android:background="@drawable/bg_skeleton" />

            <View
                android:layout_width="200dp"
                android:layout_height="14dp"
                android:layout_marginTop="@dimen/spacing_xs"
                android:background="@drawable/bg_skeleton" />

            <!-- Stat chips row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_md"
                android:baselineAligned="false"
                android:orientation="horizontal">

                <!-- Current Rank -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="80dp"
                    android:layout_marginEnd="@dimen/spacing_sm"
                    android:layout_weight="1"
                    android:background="@drawable/bg_card_yellow"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_sm">
                    <View
                        android:layout_width="60dp"
                        android:layout_height="12dp"
                        android:background="@drawable/bg_skeleton" />
                    <View
                        android:layout_width="80dp"
                        android:layout_height="24dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_skeleton" />
                </LinearLayout>

                <!-- Sessions -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="80dp"
                    android:layout_marginEnd="@dimen/spacing_sm"
                    android:layout_weight="1"
                    android:background="@drawable/bg_card_blue_bordered"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_sm">
                    <View
                        android:layout_width="60dp"
                        android:layout_height="12dp"
                        android:background="@drawable/bg_skeleton" />
                    <View
                        android:layout_width="40dp"
                        android:layout_height="24dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_skeleton" />
                </LinearLayout>

                <!-- Best Score -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="80dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_card_blue_bordered"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_sm">
                    <View
                        android:layout_width="60dp"
                        android:layout_height="12dp"
                        android:background="@drawable/bg_skeleton" />
                    <View
                        android:layout_width="50dp"
                        android:layout_height="24dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_skeleton" />
                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

        <!-- Progress Card Skeleton -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:layout_marginTop="@dimen/spacing_base"
            android:background="@drawable/bg_card_white"
            android:orientation="vertical"
            android:padding="@dimen/spacing_base">

            <View
                android:layout_width="140dp"
                android:layout_height="20dp"
                android:background="@drawable/bg_skeleton" />
            <View
                android:layout_width="match_parent"
                android:layout_height="12dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_skeleton" />
            <View
                android:layout_width="100dp"
                android:layout_height="12dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_skeleton" />

        </LinearLayout>

        <!-- Recent Sessions Skeleton -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_base"
            android:background="@drawable/bg_card_white"
            android:orientation="vertical"
            android:padding="@dimen/spacing_base">

            <View
                android:layout_width="120dp"
                android:layout_height="20dp"
                android:background="@drawable/bg_skeleton" />

            <View
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_skeleton" />
            <View
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_skeleton" />
            <View
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_skeleton" />

        </LinearLayout>

    </LinearLayout>

</com.facebook.shimmer.ShimmerFrameLayout>
