<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="@dimen/spacing_xl">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card_white"
            android:orientation="vertical"
            android:padding="@dimen/spacing_xl">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/register_title"
                android:textColor="@color/color_text_primary"
                android:textSize="@dimen/text_title"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xs"
                android:text="@string/register_subtitle"
                android:textColor="@color/color_text_secondary"
                android:textSize="@dimen/text_caption" />

            <!-- Display Name -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_base"
                android:letterSpacing="0.1"
                android:text="@string/register_display_name_label"
                android:textColor="@color/color_text_secondary"
                android:textSize="@dimen/text_label"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/et_display_name"
                android:layout_width="match_parent"
                android:layout_height="@dimen/input_height"
                android:layout_marginTop="@dimen/spacing_xs"
                android:background="@drawable/bg_input"
                android:inputType="textPersonName"
                android:padding="@dimen/spacing_md"
                android:textColor="@color/color_text_primary"
                android:textColorHint="@color/color_text_secondary"
                android:textSize="@dimen/text_body" />

            <!-- Email -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_base"
                android:letterSpacing="0.1"
                android:text="@string/login_email_label"
                android:textColor="@color/color_text_secondary"
                android:textSize="@dimen/text_label"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/et_email"
                android:layout_width="match_parent"
                android:layout_height="@dimen/input_height"
                android:layout_marginTop="@dimen/spacing_xs"
                android:background="@drawable/bg_input"
                android:hint="@string/login_email_hint"
                android:inputType="textEmailAddress"
                android:padding="@dimen/spacing_md"
                android:textColor="@color/color_text_primary"
                android:textColorHint="@color/color_text_secondary"
                android:textSize="@dimen/text_body" />

            <!-- Password -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_md"
                android:letterSpacing="0.1"
                android:text="@string/login_password_label"
                android:textColor="@color/color_text_secondary"
                android:textSize="@dimen/text_label"
                android:textStyle="bold" />

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xs">

                <EditText
                    android:id="@+id/et_password"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/input_height"
                    android:background="@drawable/bg_input"
                    android:hint="@string/login_password_hint"
                    android:inputType="textPassword"
                    android:padding="@dimen/spacing_md"
                    android:paddingEnd="@dimen/spacing_xxxl"
                    android:textColor="@color/color_text_primary"
                    android:textColorHint="@color/color_text_secondary"
                    android:textSize="@dimen/text_body" />

                <ImageButton
                    android:id="@+id/btn_toggle_password"
                    android:layout_width="@dimen/icon_size_md"
                    android:layout_height="@dimen/icon_size_md"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:layout_marginEnd="@dimen/spacing_md"
                    android:background="@android:color/transparent"
                    android:contentDescription="@string/cd_toggle_password"
                    android:scaleType="centerInside"
                    android:src="@drawable/ic_eye_off" />

            </RelativeLayout>

            <!-- Register Button -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn_register"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height"
                android:layout_marginTop="@dimen/spacing_xl"
                android:background="@drawable/bg_button_primary"
                android:text="@string/register_button"
                android:textColor="@color/color_text_primary"
                android:textSize="@dimen/text_button"
                android:textStyle="bold" />

            <!-- OR Divider -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_lg"
                android:gravity="center"
                android:orientation="horizontal">

                <View
                    android:layout_width="0dp"
                    android:layout_height="2dp"
                    android:layout_weight="1"
                    android:background="@color/color_text_primary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="@dimen/spacing_md"
                    android:text="@string/login_or"
                    android:textColor="@color/color_text_secondary"
                    android:textSize="@dimen/text_label"
                    android:textStyle="bold" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="2dp"
                    android:layout_weight="1"
                    android:background="@color/color_text_primary" />
            </LinearLayout>

            <!-- Google Login -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn_google"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height"
                android:layout_marginTop="@dimen/spacing_lg"
                android:background="@drawable/bg_button_secondary"
                android:text="@string/login_google"
                android:textColor="@color/color_text_primary"
                android:textSize="@dimen/text_button"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_login_prompt"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xl"
                android:gravity="center"
                android:text="@string/login_login_prompt"
                android:textColor="@color/color_text_primary"
                android:textSize="@dimen/text_body"
                android:textStyle="bold" />

        </LinearLayout>
    </LinearLayout>
</ScrollView>
