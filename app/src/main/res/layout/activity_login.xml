<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_surface_cream"
    android:fillViewport="true"
    tools:context=".LoginActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/spacing_xl"
        android:paddingTop="@dimen/spacing_xxxl"
        android:paddingBottom="@dimen/spacing_xxl">

        <!-- Logo -->
        <ImageView
            android:layout_width="@dimen/icon_size_xl"
            android:layout_height="@dimen/icon_size_xl"
            android:contentDescription="@string/app_name"
            android:src="@drawable/ic_logo_t" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_sm"
            android:text="@string/app_name"
            android:textColor="@color/color_text_primary"
            android:textSize="@dimen/text_headline"
            android:textStyle="bold" />

        <!-- Hero Text -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xxl"
            android:lineSpacingExtra="4dp"
            android:text="@string/login_hero_text"
            android:textColor="@color/color_text_primary"
            android:textSize="@dimen/text_headline"
            android:textStyle="bold" />

        <!-- Feature Items -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xl"
            android:orientation="vertical">

            <!-- Feature 1: Yellow check -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_md"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="@dimen/icon_size_md"
                    android:layout_height="@dimen/icon_size_md"
                    android:background="@drawable/bg_check_yellow"
                    android:contentDescription="@null"
                    android:padding="@dimen/spacing_xs"
                    android:src="@drawable/ic_check" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/spacing_md"
                    android:text="@string/login_feature_1"
                    android:textColor="@color/color_text_primary"
                    android:textSize="@dimen/text_body" />

            </LinearLayout>

            <!-- Feature 2: Teal check -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_md"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="@dimen/icon_size_md"
                    android:layout_height="@dimen/icon_size_md"
                    android:background="@drawable/bg_check_teal"
                    android:contentDescription="@null"
                    android:padding="@dimen/spacing_xs"
                    android:src="@drawable/ic_check" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/spacing_md"
                    android:text="@string/login_feature_2"
                    android:textColor="@color/color_text_primary"
                    android:textSize="@dimen/text_body" />

            </LinearLayout>

            <!-- Feature 3: Green check -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_md"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="@dimen/icon_size_md"
                    android:layout_height="@dimen/icon_size_md"
                    android:background="@drawable/bg_check_green"
                    android:contentDescription="@null"
                    android:padding="@dimen/spacing_xs"
                    android:src="@drawable/ic_check" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/spacing_md"
                    android:text="@string/login_feature_3"
                    android:textColor="@color/color_text_primary"
                    android:textSize="@dimen/text_body" />

            </LinearLayout>

            <!-- Feature 4: Blue check -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_md"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="@dimen/icon_size_md"
                    android:layout_height="@dimen/icon_size_md"
                    android:background="@drawable/bg_check_blue"
                    android:contentDescription="@null"
                    android:padding="@dimen/spacing_xs"
                    android:src="@drawable/ic_check" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/spacing_md"
                    android:text="@string/login_feature_4"
                    android:textColor="@color/color_text_primary"
                    android:textSize="@dimen/text_body" />

            </LinearLayout>

        </LinearLayout>

        <!-- Login Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xl"
            android:background="@drawable/bg_card_white"
            android:orientation="vertical"
            android:padding="@dimen/spacing_xl">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/login_card_title"
                android:textColor="@color/color_text_primary"
                android:textSize="@dimen/text_title"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xs"
                android:text="@string/login_card_subtitle"
                android:textColor="@color/color_text_secondary"
                android:textSize="@dimen/text_caption" />

            <!-- Email -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_base"
                android:letterSpacing="0.1"
                android:text="@string/login_email_label"
                android:textColor="@color/color_text_secondary"
                android:textSize="@dimen/text_label"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/et_email"
                android:layout_width="match_parent"
                android:layout_height="@dimen/input_height"
                android:layout_marginTop="@dimen/spacing_xs"
                android:background="@drawable/bg_input"
                android:hint="@string/login_email_hint"
                android:inputType="textEmailAddress"
                android:padding="@dimen/spacing_md"
                android:textColor="@color/color_text_primary"
                android:textColorHint="@color/color_text_secondary"
                android:textSize="@dimen/text_body" />

            <!-- Password -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_md"
                android:letterSpacing="0.1"
                android:text="@string/login_password_label"
                android:textColor="@color/color_text_secondary"
                android:textSize="@dimen/text_label"
                android:textStyle="bold" />

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xs">

                <EditText
                    android:id="@+id/et_password"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/input_height"
                    android:background="@drawable/bg_input"
                    android:hint="@string/login_password_hint"
                    android:inputType="textPassword"
                    android:padding="@dimen/spacing_md"
                    android:paddingEnd="@dimen/spacing_xxxl"
                    android:textColor="@color/color_text_primary"
                    android:textColorHint="@color/color_text_secondary"
                    android:textSize="@dimen/text_body" />

                <ImageButton
                    android:id="@+id/btn_toggle_password"
                    android:layout_width="@dimen/icon_size_md"
                    android:layout_height="@dimen/icon_size_md"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:layout_marginEnd="@dimen/spacing_md"
                    android:background="@android:color/transparent"
                    android:contentDescription="@string/cd_toggle_password"
                    android:scaleType="centerInside"
                    android:src="@drawable/ic_eye_off" />

            </RelativeLayout>

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn_login"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height"
                android:layout_marginTop="@dimen/spacing_lg"
                android:background="@drawable/bg_button_primary"
                android:text="@string/login_button"
                android:textAllCaps="true"
                android:textColor="@color/color_text_primary"
                android:textSize="@dimen/text_body"
                android:textStyle="bold" />

            <!-- Divider -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_base"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="@color/color_border" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="@dimen/spacing_md"
                    android:text="@string/login_divider"
                    android:textColor="@color/color_text_secondary"
                    android:textSize="@dimen/text_caption" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="@color/color_border" />

            </LinearLayout>

            <!-- Google Button -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn_google"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height"
                android:layout_marginTop="@dimen/spacing_base"
                android:background="@drawable/bg_button_secondary"
                android:text="@string/login_google_button"
                android:textColor="@color/color_text_primary"
                android:textSize="@dimen/text_body"
                android:textStyle="bold" />

            <!-- Register Prompt -->
            <TextView
                android:id="@+id/tv_register_prompt"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="@dimen/spacing_base"
                android:text="@string/login_register_prompt"
                android:textColor="@color/color_text_secondary"
                android:textSize="@dimen/text_caption" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>
