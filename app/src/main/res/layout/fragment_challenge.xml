<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_background"
    tools:context=".ChallengeFragment">

    <!-- Scrollable Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/bottom_sticky_bar"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="24dp">

            <!-- ==================== Header ==================== -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:letterSpacing="0.1"
                android:text="Ranked Arena"
                android:textAllCaps="true"
                android:textColor="@color/color_text_secondary"
                android:textSize="@dimen/text_label"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Prepare your next round"
                android:textColor="@color/color_text_primary"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Configure the round, lock your choices, then enter the arena."
                android:textColor="@color/color_text_secondary"
                android:textSize="@dimen/text_caption" />

            <!-- Verified Badge (Compact) -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="@dimen/icon_size_sm"
                    android:layout_height="@dimen/icon_size_sm"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_verified"
                    app:tint="@color/color_accent_green" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/spacing_xs"
                    android:text="VERIFIED RESULTS"
                    android:textColor="@color/color_accent_green"
                    android:textSize="11dp"
                    android:textStyle="bold" />

            </LinearLayout>

            <!-- ==================== Compact Status Card ==================== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_card_white"
                android:orientation="vertical"
                android:padding="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="2 required selections"
                        android:textColor="@color/color_text_primary"
                        android:textStyle="bold"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/tv_steps_ready"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0/2 selected"
                        android:textColor="@color/color_text_secondary"
                        android:textStyle="bold"
                        android:textSize="11sp" />

                </LinearLayout>

                <ProgressBar
                    android:id="@+id/pb_steps"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="4dp"
                    android:layout_marginTop="8dp"
                    android:max="100"
                    android:progress="0"
                    android:progressDrawable="@drawable/bg_progress_fill" />

            </LinearLayout>

            <!-- ==================== Section 01: Choose Session Type ==================== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1. Choose Session Type"
                    android:textColor="@color/color_text_primary"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal">

                    <!-- Quick Round Card -->
                    <FrameLayout
                        android:id="@+id/card_quick"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="10dp"
                        android:background="@drawable/bg_card_white"
                        android:padding="12dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:orientation="vertical">

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:contentDescription="@null"
                                android:src="@drawable/ic_bolt" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="Quick"
                                android:textColor="@color/color_text_primary"
                                android:textSize="13sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="5Q · ~1 min"
                                android:textColor="@color/color_text_secondary"
                                android:textSize="11sp" />

                        </LinearLayout>

                        <ImageView
                            android:id="@+id/iv_check_quick"
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:layout_gravity="top|end"
                            android:src="@drawable/ic_check"
                            android:visibility="invisible"
                            app:tint="@color/color_text_primary" />

                        <RadioButton
                            android:id="@+id/rb_quick"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:visibility="gone" />

                    </FrameLayout>

                    <!-- Standard Round Card -->
                    <FrameLayout
                        android:id="@+id/card_standard"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginHorizontal="5dp"
                        android:background="@drawable/bg_card_white"
                        android:padding="12dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:orientation="vertical">

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:contentDescription="@null"
                                android:src="@drawable/ic_chart" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="Standard"
                                android:textColor="@color/color_text_primary"
                                android:textSize="13sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="10Q · ~2 min"
                                android:textColor="@color/color_text_secondary"
                                android:textSize="11sp" />

                        </LinearLayout>

                        <ImageView
                            android:id="@+id/iv_check_standard"
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:layout_gravity="top|end"
                            android:src="@drawable/ic_check"
                            android:visibility="invisible"
                            app:tint="@color/color_text_primary" />

                        <RadioButton
                            android:id="@+id/rb_standard"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:visibility="gone" />

                    </FrameLayout>

                    <!-- Extended Round Card -->
                    <FrameLayout
                        android:id="@+id/card_extended"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="10dp"
                        android:background="@drawable/bg_card_white"
                        android:padding="12dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:orientation="vertical">

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:contentDescription="@null"
                                android:src="@drawable/ic_timer" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="Long"
                                android:textColor="@color/color_text_primary"
                                android:textSize="13sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="20Q · ~4 min"
                                android:textColor="@color/color_text_secondary"
                                android:textSize="11sp" />

                        </LinearLayout>

                        <ImageView
                            android:id="@+id/iv_check_extended"
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:layout_gravity="top|end"
                            android:src="@drawable/ic_check"
                            android:visibility="invisible"
                            app:tint="@color/color_text_primary" />

                        <RadioButton
                            android:id="@+id/rb_extended"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:visibility="gone" />

                    </FrameLayout>

                </LinearLayout>
            </LinearLayout>

            <!-- ==================== Section 02: Choose Mode ==================== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2. Choose Mode"
                    android:textColor="@color/color_text_primary"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <!-- Mixed Mode Card (Full width compact bar) -->
                <LinearLayout
                    android:id="@+id/card_mixed"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_card_white"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="12dp">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_mixed" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="Mixed Mode"
                        android:textColor="@color/color_text_primary"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <Space
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:layout_weight="1" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="All Categories"
                        android:textColor="@color/color_text_secondary"
                        android:textSize="11sp" />

                    <ImageView
                        android:id="@+id/iv_check_mixed"
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_marginStart="8dp"
                        android:src="@drawable/ic_check"
                        android:visibility="invisible"
                        app:tint="@color/color_text_primary" />

                    <RadioButton
                        android:id="@+id/rb_mixed"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:visibility="gone" />

                </LinearLayout>

                <!-- Row 1: Number & Symbol Patterns -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal">

                    <!-- Number Patterns -->
                    <LinearLayout
                        android:id="@+id/card_number"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:layout_marginEnd="5dp"
                        android:background="@drawable/bg_card_white"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="12dp">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_chart" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            android:layout_marginEnd="4dp"
                            android:text="Number Patterns"
                            android:textColor="@color/color_text_primary"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <ImageView
                            android:id="@+id/iv_check_number"
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_check"
                            android:visibility="invisible"
                            app:tint="@color/color_text_primary" />

                        <RadioButton
                            android:id="@+id/rb_number"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:visibility="gone" />

                    </LinearLayout>

                    <!-- Symbol Patterns -->
                    <LinearLayout
                        android:id="@+id/card_symbol"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:layout_marginStart="5dp"
                        android:background="@drawable/bg_card_white"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="12dp">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_symbol" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            android:layout_marginEnd="4dp"
                            android:text="Symbol Patterns"
                            android:textColor="@color/color_text_primary"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <ImageView
                            android:id="@+id/iv_check_symbol"
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_check"
                            android:visibility="invisible"
                            app:tint="@color/color_text_primary" />

                        <RadioButton
                            android:id="@+id/rb_symbol"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:visibility="gone" />

                    </LinearLayout>

                </LinearLayout>

                <!-- Row 2: Mini Deduction & Pattern Memory -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal">

                    <!-- Mini Deduction -->
                    <LinearLayout
                        android:id="@+id/card_deduction"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:layout_marginEnd="5dp"
                        android:background="@drawable/bg_card_white"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="12dp">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_deduction" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            android:layout_marginEnd="4dp"
                            android:text="Mini Deduction"
                            android:textColor="@color/color_text_primary"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <ImageView
                            android:id="@+id/iv_check_deduction"
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_check"
                            android:visibility="invisible"
                            app:tint="@color/color_text_primary" />

                        <RadioButton
                            android:id="@+id/rb_deduction"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:visibility="gone" />

                    </LinearLayout>

                    <!-- Pattern Memory -->
                    <LinearLayout
                        android:id="@+id/card_memory"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:layout_marginStart="5dp"
                        android:background="@drawable/bg_card_white"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="12dp">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_memory" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            android:layout_marginEnd="4dp"
                            android:text="Pattern Memory"
                            android:textColor="@color/color_text_primary"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <ImageView
                            android:id="@+id/iv_check_memory"
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_check"
                            android:visibility="invisible"
                            app:tint="@color/color_text_primary" />

                        <RadioButton
                            android:id="@+id/rb_memory"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:visibility="gone" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

            <!-- Loadout Preview Card (Always visible, stable position, neutral default text) -->
            <TextView
                android:id="@+id/tv_loadout_preview"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:minHeight="44dp"
                android:background="@drawable/bg_card_white_small"
                android:gravity="center"
                android:padding="10dp"
                android:text="Choose a session and mode"
                android:textColor="@color/color_text_primary"
                android:textSize="12sp"
                android:textStyle="bold"
                android:visibility="visible" />

            <!-- Spacer at the bottom to allow scrolling past the sticky bottom bar -->
            <Space
                android:layout_width="match_parent"
                android:layout_height="48dp" />

        </LinearLayout>
    </ScrollView>

    <!-- Sticky Bottom Action Bar -->
    <LinearLayout
        android:id="@+id/bottom_sticky_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="@drawable/bg_sticky_bottom_bar"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingTop="14dp"
        android:paddingBottom="12dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Selected Loadout"
                android:textColor="#555555"
                android:textSize="10sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_sticky_selection"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Choose 2 options"
                android:textColor="@color/color_text_primary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:singleLine="true"
                android:maxLines="1"
                android:ellipsize="end" />

        </LinearLayout>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_choose_config"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:minWidth="150dp"
            android:paddingHorizontal="14dp"
            android:background="@drawable/bg_button_disabled"
            android:enabled="false"
            android:text="Choose session and mode"
            android:textColor="@color/color_text_secondary"
            android:textSize="12sp"
            android:textStyle="bold" />

    </LinearLayout>

</RelativeLayout>
