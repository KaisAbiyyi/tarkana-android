<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_base">

        <!-- ==================== Header ==================== -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:letterSpacing="0.1"
            android:text="@string/challenge_label"
            android:textAllCaps="true"
            android:textColor="@color/color_text_secondary"
            android:textSize="@dimen/text_label"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xs"
            android:text="@string/challenge_title"
            android:textColor="@color/color_text_primary"
            android:textSize="@dimen/text_display"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_sm"
            android:text="@string/challenge_subtitle"
            android:textColor="@color/color_text_secondary"
            android:textSize="@dimen/text_caption" />

        <!-- Verified Badge -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="@dimen/icon_size_sm"
                android:layout_height="@dimen/icon_size_sm"
                android:contentDescription="@null"
                android:src="@drawable/ic_verified"
                app:tint="@color/color_accent_green"
                xmlns:app="http://schemas.android.com/apk/res-auto" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_xs"
                android:text="@string/challenge_verified"
                android:textColor="@color/color_accent_green"
                android:textSize="@dimen/text_caption"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- ==================== Progress Card ==================== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_base"
            android:background="@drawable/bg_card_white"
            android:orientation="vertical"
            android:padding="@dimen/spacing_base">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:letterSpacing="0.1"
                android:text="@string/challenge_prep_label"
                android:textAllCaps="true"
                android:textColor="@color/color_text_secondary"
                android:textSize="@dimen/text_label"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/challenge_prep_subtitle"
                    android:textColor="@color/color_text_secondary"
                    android:textSize="@dimen/text_body" />

                <TextView
                    android:id="@+id/tv_steps_ready"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/challenge_steps_ready"
                    android:textColor="@color/color_text_primary"
                    android:textSize="@dimen/text_caption"
                    android:textStyle="bold" />

            </LinearLayout>

            <ProgressBar
                android:id="@+id/pb_steps"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="@dimen/progress_height"
                android:layout_marginTop="@dimen/spacing_sm"
                android:max="3"
                android:progress="0"
                android:progressDrawable="@drawable/bg_progress_fill" />

            <!-- Step Labels -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_md"
                android:orientation="horizontal">

                <!-- Step 1 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="@dimen/icon_size_md"
                        android:layout_height="@dimen/icon_size_md"
                        android:background="@drawable/bg_step_active"
                        android:gravity="center"
                        android:text="@string/step_1"
                        android:textColor="@android:color/white"
                        android:textSize="@dimen/text_caption"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_xs"
                        android:text="@string/challenge_step_session"
                        android:textColor="@color/color_text_secondary"
                        android:textSize="@dimen/text_label" />

                </LinearLayout>

                <!-- Step 2 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="@dimen/icon_size_md"
                        android:layout_height="@dimen/icon_size_md"
                        android:background="@drawable/bg_step_inactive"
                        android:gravity="center"
                        android:text="@string/step_2"
                        android:textColor="@color/color_text_secondary"
                        android:textSize="@dimen/text_caption"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_xs"
                        android:text="@string/challenge_step_mode"
                        android:textColor="@color/color_text_secondary"
                        android:textSize="@dimen/text_label" />

                </LinearLayout>

                <!-- Step 3 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="@dimen/icon_size_md"
                        android:layout_height="@dimen/icon_size_md"
                        android:background="@drawable/bg_step_inactive"
                        android:gravity="center"
                        android:text="@string/step_3"
                        android:textColor="@color/color_text_secondary"
                        android:textSize="@dimen/text_caption"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_xs"
                        android:text="@string/challenge_step_review"
                        android:textColor="@color/color_text_secondary"
                        android:textSize="@dimen/text_label" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

        <!-- ==================== Section 01: Choose Session Type ==================== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xl"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="@dimen/icon_size_md"
                android:layout_height="@dimen/icon_size_md"
                android:background="@drawable/bg_step_active"
                android:gravity="center"
                android:text="@string/section_01"
                android:textColor="@android:color/white"
                android:textSize="@dimen/text_caption"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_md"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/challenge_session_title"
                    android:textColor="@color/color_text_primary"
                    android:textSize="@dimen/text_title"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/challenge_session_subtitle"
                    android:textColor="@color/color_text_secondary"
                    android:textSize="@dimen/text_caption" />

            </LinearLayout>

        </LinearLayout>

        <!-- Session Type Cards (Stacked Vertically) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            android:orientation="vertical">

            <!-- Quick Round Card -->
            <LinearLayout
                android:id="@+id/card_quick"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_sm"
                android:background="@drawable/bg_card_white"
                android:orientation="vertical"
                android:padding="@dimen/spacing_base">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="@dimen/icon_size_lg"
                        android:layout_height="@dimen/icon_size_lg"
                        android:background="@drawable/bg_border_black"
                        android:contentDescription="@null"
                        android:padding="@dimen/spacing_xs"
                        android:src="@drawable/ic_bolt" />

                    <Space
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:layout_weight="1" />

                    <RadioButton
                        android:id="@+id/rb_quick"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />

                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_sm"
                    android:text="@string/challenge_quick_title"
                    android:textColor="@color/color_text_primary"
                    android:textSize="@dimen/text_body"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_xs"
                    android:text="@string/challenge_quick_desc"
                    android:textColor="@color/color_text_secondary"
                    android:textSize="@dimen/text_caption" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_xs"
                    android:text="@string/challenge_quick_detail"
                    android:textColor="@color/color_text_primary"
                    android:textSize="@dimen/text_caption" />

            </LinearLayout>

            <!-- Standard Round Card -->
            <LinearLayout
                android:id="@+id/card_standard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_sm"
                android:background="@drawable/bg_card_white"
                android:orientation="vertical"
                android:padding="@dimen/spacing_base">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="@dimen/icon_size_lg"
                        android:layout_height="@dimen/icon_size_lg"
                        android:background="@drawable/bg_border_black"
                        android:contentDescription="@null"
                        android:padding="@dimen/spacing_xs"
                        android:src="@drawable/ic_chart" />

                    <Space
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:layout_weight="1" />

                    <RadioButton
                        android:id="@+id/rb_standard"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />

                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_sm"
                    android:text="@string/challenge_standard_title"
                    android:textColor="@color/color_text_primary"
                    android:textSize="@dimen/text_body"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_xs"
                    android:text="@string/challenge_standard_desc"
                    android:textColor="@color/color_text_secondary"
                    android:textSize="@dimen/text_caption" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_xs"
                    android:text="@string/challenge_standard_detail"
                    android:textColor="@color/color_text_primary"
                    android:textSize="@dimen/text_caption" />

            </LinearLayout>

            <!-- Extended Round Card -->
            <LinearLayout
                android:id="@+id/card_extended"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card_white"
                android:orientation="vertical"
                android:padding="@dimen/spacing_base">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="@dimen/icon_size_lg"
                        android:layout_height="@dimen/icon_size_lg"
                        android:background="@drawable/bg_border_black"
                        android:contentDescription="@null"
                        android:padding="@dimen/spacing_xs"
                        android:src="@drawable/ic_timer" />

                    <Space
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:layout_weight="1" />

                    <RadioButton
                        android:id="@+id/rb_extended"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />

                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_sm"
                    android:text="@string/challenge_extended_title"
                    android:textColor="@color/color_text_primary"
                    android:textSize="@dimen/text_body"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_xs"
                    android:text="@string/challenge_extended_desc"
                    android:textColor="@color/color_text_secondary"
                    android:textSize="@dimen/text_caption" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_xs"
                    android:text="@string/challenge_extended_detail"
                    android:textColor="@color/color_text_primary"
                    android:textSize="@dimen/text_caption" />

            </LinearLayout>

        </LinearLayout>

        <!-- ==================== Section 02: Choose Mode ==================== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xl"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="@dimen/icon_size_md"
                android:layout_height="@dimen/icon_size_md"
                android:background="@drawable/bg_step_inactive"
                android:gravity="center"
                android:text="@string/section_02"
                android:textColor="@color/color_text_secondary"
                android:textSize="@dimen/text_caption"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_md"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/challenge_mode_title"
                    android:textColor="@color/color_text_primary"
                    android:textSize="@dimen/text_title"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/challenge_mode_subtitle"
                    android:textColor="@color/color_text_secondary"
                    android:textSize="@dimen/text_caption" />

            </LinearLayout>

        </LinearLayout>

        <!-- Mixed Mode Card -->
        <LinearLayout
            android:id="@+id/card_mixed"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            android:background="@drawable/bg_card_white"
            android:orientation="vertical"
            android:padding="@dimen/spacing_base">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="@dimen/icon_size_lg"
                    android:layout_height="@dimen/icon_size_lg"
                    android:background="@drawable/bg_border_black"
                    android:contentDescription="@null"
                    android:padding="@dimen/spacing_xs"
                    android:src="@drawable/ic_mixed" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/spacing_md"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/challenge_mixed_title"
                        android:textColor="@color/color_text_primary"
                        android:textSize="@dimen/text_body"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/challenge_mixed_desc"
                        android:textColor="@color/color_text_secondary"
                        android:textSize="@dimen/text_caption" />

                </LinearLayout>

                <RadioButton
                    android:id="@+id/rb_mixed"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

            </LinearLayout>

            <!-- Category Chips -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_md"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="@dimen/chip_height"
                        android:layout_marginBottom="@dimen/spacing_xs"
                        android:layout_marginEnd="@dimen/spacing_xs"
                        android:background="@drawable/bg_chip_outline"
                        android:gravity="center"
                        android:paddingHorizontal="@dimen/spacing_sm"
                        android:text="@string/challenge_chip_number"
                        android:textColor="@color/color_text_primary"
                        android:textSize="@dimen/text_label" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="@dimen/chip_height"
                        android:layout_marginBottom="@dimen/spacing_xs"
                        android:background="@drawable/bg_chip_outline"
                        android:gravity="center"
                        android:paddingHorizontal="@dimen/spacing_sm"
                        android:text="@string/challenge_chip_symbol"
                        android:textColor="@color/color_text_primary"
                        android:textSize="@dimen/text_label" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="@dimen/chip_height"
                        android:layout_marginEnd="@dimen/spacing_xs"
                        android:background="@drawable/bg_chip_outline"
                        android:gravity="center"
                        android:paddingHorizontal="@dimen/spacing_sm"
                        android:text="@string/challenge_chip_deduction"
                        android:textColor="@color/color_text_primary"
                        android:textSize="@dimen/text_label" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="@dimen/chip_height"
                        android:background="@drawable/bg_chip_outline"
                        android:gravity="center"
                        android:paddingHorizontal="@dimen/spacing_sm"
                        android:text="@string/challenge_chip_memory"
                        android:textColor="@color/color_text_primary"
                        android:textSize="@dimen/text_label" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

        <!-- Mode Cards Stacked Vertically -->
        <!-- Number Patterns -->
        <LinearLayout
            android:id="@+id/card_number"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_sm"
            android:background="@drawable/bg_card_white"
            android:orientation="vertical"
            android:padding="@dimen/spacing_md">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="@dimen/icon_size_md"
                    android:layout_height="@dimen/icon_size_md"
                    android:background="@drawable/bg_border_black"
                    android:contentDescription="@null"
                    android:padding="@dimen/spacing_xs"
                    android:src="@drawable/ic_number" />

                <Space
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <RadioButton
                    android:id="@+id/rb_number"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                android:text="@string/challenge_number_title"
                android:textColor="@color/color_text_primary"
                android:textSize="@dimen/text_body"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xs"
                android:text="@string/challenge_number_desc"
                android:textColor="@color/color_text_secondary"
                android:textSize="@dimen/text_caption" />

        </LinearLayout>

        <!-- Symbol Patterns -->
        <LinearLayout
            android:id="@+id/card_symbol"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_sm"
            android:background="@drawable/bg_card_white"
            android:orientation="vertical"
            android:padding="@dimen/spacing_md">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="@dimen/icon_size_md"
                    android:layout_height="@dimen/icon_size_md"
                    android:background="@drawable/bg_border_black"
                    android:contentDescription="@null"
                    android:padding="@dimen/spacing_xs"
                    android:src="@drawable/ic_symbol" />

                <Space
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <RadioButton
                    android:id="@+id/rb_symbol"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                android:text="@string/challenge_symbol_title"
                android:textColor="@color/color_text_primary"
                android:textSize="@dimen/text_body"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xs"
                android:text="@string/challenge_symbol_desc"
                android:textColor="@color/color_text_secondary"
                android:textSize="@dimen/text_caption" />

        </LinearLayout>

        <!-- Mini Deduction -->
        <LinearLayout
            android:id="@+id/card_deduction"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_sm"
            android:background="@drawable/bg_card_white"
            android:orientation="vertical"
            android:padding="@dimen/spacing_md">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="@dimen/icon_size_md"
                    android:layout_height="@dimen/icon_size_md"
                    android:background="@drawable/bg_border_black"
                    android:contentDescription="@null"
                    android:padding="@dimen/spacing_xs"
                    android:src="@drawable/ic_deduction" />

                <Space
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <RadioButton
                    android:id="@+id/rb_deduction"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                android:text="@string/challenge_deduction_title"
                android:textColor="@color/color_text_primary"
                android:textSize="@dimen/text_body"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xs"
                android:text="@string/challenge_deduction_desc"
                android:textColor="@color/color_text_secondary"
                android:textSize="@dimen/text_caption" />

        </LinearLayout>

        <!-- Pattern Memory -->
        <LinearLayout
            android:id="@+id/card_memory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_sm"
            android:background="@drawable/bg_card_white"
            android:orientation="vertical"
            android:padding="@dimen/spacing_md">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="@dimen/icon_size_md"
                    android:layout_height="@dimen/icon_size_md"
                    android:background="@drawable/bg_border_black"
                    android:contentDescription="@null"
                    android:padding="@dimen/spacing_xs"
                    android:src="@drawable/ic_memory" />

                <Space
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <RadioButton
                    android:id="@+id/rb_memory"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                android:text="@string/challenge_memory_title"
                android:textColor="@color/color_text_primary"
                android:textSize="@dimen/text_body"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xs"
                android:text="@string/challenge_memory_desc"
                android:textColor="@color/color_text_secondary"
                android:textSize="@dimen/text_caption" />

        </LinearLayout>

        <!-- ==================== Summary Card ==================== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xl"
            android:background="@drawable/bg_card_yellow"
            android:orientation="vertical"
            android:padding="@dimen/spacing_base">

            <ImageView
                android:layout_width="@dimen/icon_size_xl"
                android:layout_height="@dimen/icon_size_xl"
                android:layout_marginBottom="@dimen/spacing_md"
                android:contentDescription="@null"
                android:src="@drawable/ic_question_mark" />

            <TextView
                android:id="@+id/tv_summary_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/challenge_summary_title"
                android:textColor="@color/color_text_primary"
                android:textSize="@dimen/text_headline"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_summary_subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xs"
                android:text="@string/challenge_summary_session"
                android:textColor="@color/color_text_secondary"
                android:textSize="@dimen/text_caption" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                android:text="@string/challenge_summary_desc"
                android:textColor="@color/color_text_secondary"
                android:textSize="@dimen/text_body" />

            <!-- Info Boxes 2x2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_base"
                android:orientation="vertical">

                <!-- Row 1 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="@dimen/spacing_sm"
                        android:layout_weight="1"
                        android:background="@drawable/bg_border_black"
                        android:orientation="vertical"
                        android:padding="@dimen/spacing_md">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/challenge_info_duration"
                            android:textColor="@color/color_text_secondary"
                            android:textSize="@dimen/text_label" />

                        <TextView
                            android:id="@+id/tv_summary_duration"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/placeholder_dash"
                            android:textColor="@color/color_text_primary"
                            android:textSize="@dimen/text_body"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/bg_border_black"
                        android:orientation="vertical"
                        android:padding="@dimen/spacing_md">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/challenge_info_count"
                            android:textColor="@color/color_text_secondary"
                            android:textSize="@dimen/text_label" />

                        <TextView
                            android:id="@+id/tv_summary_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/placeholder_dash"
                            android:textColor="@color/color_text_primary"
                            android:textSize="@dimen/text_body"
                            android:textStyle="bold" />

                    </LinearLayout>

                </LinearLayout>

                <!-- Row 2 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_sm"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="@dimen/spacing_sm"
                        android:layout_weight="1"
                        android:background="@drawable/bg_border_black"
                        android:orientation="vertical"
                        android:padding="@dimen/spacing_md">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/challenge_info_status"
                            android:textColor="@color/color_text_secondary"
                            android:textSize="@dimen/text_label" />

                        <TextView
                            android:id="@+id/tv_summary_status"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/placeholder_dash"
                            android:textColor="@color/color_text_primary"
                            android:textSize="@dimen/text_body"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/bg_border_black"
                        android:orientation="vertical"
                        android:padding="@dimen/spacing_md">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/challenge_info_review"
                            android:textColor="@color/color_text_secondary"
                            android:textSize="@dimen/text_label" />

                        <TextView
                            android:id="@+id/tv_summary_review"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/placeholder_dash"
                            android:textColor="@color/color_text_primary"
                            android:textSize="@dimen/text_body"
                            android:textStyle="bold" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

            <!-- Verified Score -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_md"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="@dimen/icon_size_sm"
                    android:layout_height="@dimen/icon_size_sm"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_verified"
                    xmlns:app="http://schemas.android.com/apk/res-auto"
                    app:tint="@color/color_accent_green" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/spacing_xs"
                    android:text="@string/challenge_verified_score"
                    android:textColor="@color/color_text_secondary"
                    android:textSize="@dimen/text_caption" />

            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xs"
                android:text="@string/challenge_rank_info"
                android:textColor="@color/color_text_secondary"
                android:textSize="@dimen/text_caption" />

            <!-- Choose Configuration Button -->
            <Button
                android:id="@+id/btn_choose_config"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height"
                android:layout_marginTop="@dimen/spacing_base"
                android:background="@drawable/bg_button_disabled"
                android:backgroundTint="@null"
                android:enabled="false"
                android:text="@string/challenge_choose_config"
                android:textColor="@color/color_text_secondary"
                android:textSize="@dimen/text_body"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                android:gravity="center"
                android:text="@string/challenge_footer"
                android:textColor="@color/color_text_secondary"
                android:textSize="@dimen/text_caption" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>
