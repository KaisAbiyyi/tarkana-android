<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_background"
    android:orientation="vertical"
    android:padding="@dimen/spacing_xl">

    <!-- Top text -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="RANKED ARENA"
        android:textColor="@color/color_text_secondary"
        android:textSize="@dimen/text_label"
        android:textStyle="bold"
        android:letterSpacing="0.1" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_xs"
        android:text="@string/session_symbol_patterns"
        android:textColor="@color/color_text_primary"
        android:textSize="48sp"
        android:textStyle="bold" />

    <!-- Status Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_lg"
        android:background="@drawable/bg_card_white"
        android:orientation="vertical"
        android:paddingBottom="@dimen/spacing_sm">

        <!-- Info row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:baselineAligned="false">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="@dimen/spacing_sm">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/session_progress"
                    android:textColor="@color/color_text_secondary"
                    android:textSize="@dimen/text_caption"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Question 1 of 10"
                    android:textColor="@color/color_text_primary"
                    android:textSize="@dimen/text_body"
                    android:textStyle="bold" />
            </LinearLayout>

            <View android:layout_width="2dp" android:layout_height="match_parent" android:background="@color/color_text_primary" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="@dimen/spacing_sm">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/session_streak"
                    android:textColor="@color/color_text_secondary"
                    android:textSize="@dimen/text_caption"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="@color/color_text_primary"
                    android:textSize="@dimen/text_body"
                    android:textStyle="bold" />
            </LinearLayout>

            <View android:layout_width="2dp" android:layout_height="match_parent" android:background="@color/color_text_primary" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="@dimen/spacing_sm">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/session_score"
                    android:textColor="@color/color_text_secondary"
                    android:textSize="@dimen/text_caption"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="@color/color_text_primary"
                    android:textSize="@dimen/text_body"
                    android:textStyle="bold" />
            </LinearLayout>

            <View android:layout_width="2dp" android:layout_height="match_parent" android:background="@color/color_text_primary" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="@dimen/spacing_sm">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/session_time_left"
                    android:textColor="@color/color_text_secondary"
                    android:textSize="@dimen/text_caption"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="24s"
                    android:textColor="@color/color_text_primary"
                    android:textSize="@dimen/text_body"
                    android:textStyle="bold" />
            </LinearLayout>

        </LinearLayout>

        <!-- Progress bar -->
        <ProgressBar
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="12dp"
            android:layout_marginHorizontal="@dimen/spacing_md"
            android:layout_marginTop="@dimen/spacing_xs"
            android:max="100"
            android:progress="15"
            android:progressDrawable="@drawable/bg_progress_fill"
            android:background="@drawable/bg_card_white" />

    </LinearLayout>

    <Space
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Question Box -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_card_white"
        android:orientation="vertical"
        android:padding="@dimen/spacing_lg">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:text="Question 1"
            android:textColor="@color/color_text_secondary"
            android:textSize="@dimen/text_body"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xs"
            android:text="@string/session_find_next"
            android:textColor="@color/color_text_primary"
            android:textSize="@dimen/text_headline"
            android:textStyle="bold" />

        <!-- Symbols row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_lg"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/bg_card_yellow_bordered"
                android:padding="@dimen/spacing_xs"
                android:src="@drawable/ic_shape_star" />

            <ImageView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginStart="@dimen/spacing_sm"
                android:background="@drawable/bg_card_red_bordered"
                android:padding="@dimen/spacing_xs"
                android:src="@drawable/ic_shape_diamond" />

            <ImageView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginStart="@dimen/spacing_sm"
                android:background="@drawable/bg_card_blue_bordered"
                android:padding="@dimen/spacing_xs"
                android:src="@drawable/ic_shape_square" />

            <ImageView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginStart="@dimen/spacing_sm"
                android:background="@drawable/bg_card_teal_bordered"
                android:padding="@dimen/spacing_xs"
                android:src="@drawable/ic_shape_circle" />

            <ImageView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginStart="@dimen/spacing_sm"
                android:background="@drawable/bg_card_yellow_bordered"
                android:padding="@dimen/spacing_xs"
                android:src="@drawable/ic_shape_star" />

            <!-- Question mark box -->
            <TextView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginStart="@dimen/spacing_sm"
                android:background="@drawable/bg_card_blue_bordered"
                android:gravity="center"
                android:text="?"
                android:textColor="@color/color_text_primary"
                android:textSize="@dimen/text_title"
                android:textStyle="bold" />

        </LinearLayout>

    </LinearLayout>

    <!-- Options 2x2 grid -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_md"
        android:orientation="horizontal">

        <LinearLayout
            android:id="@+id/card_option_a"
            android:layout_width="0dp"
            android:layout_height="64dp"
            android:layout_weight="1"
            android:layout_marginEnd="@dimen/spacing_xs"
            android:background="@drawable/bg_card_white"
            android:gravity="center"
            android:orientation="horizontal"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:background="@drawable/bg_badge_yellow"
                android:gravity="center"
                android:text="A"
                android:textColor="@color/color_text_primary"
                android:textSize="@dimen/text_caption"
                android:textStyle="bold" />

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginStart="@dimen/spacing_md"
                android:background="@drawable/bg_card_blue_bordered"
                android:src="@drawable/ic_shape_square" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/card_option_b"
            android:layout_width="0dp"
            android:layout_height="64dp"
            android:layout_weight="1"
            android:layout_marginStart="@dimen/spacing_xs"
            android:background="@drawable/bg_card_white"
            android:gravity="center"
            android:orientation="horizontal"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:background="@drawable/bg_badge_yellow"
                android:gravity="center"
                android:text="B"
                android:textColor="@color/color_text_primary"
                android:textSize="@dimen/text_caption"
                android:textStyle="bold" />

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginStart="@dimen/spacing_md"
                android:background="@drawable/bg_card_red_bordered"
                android:src="@drawable/ic_shape_diamond" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_sm"
        android:orientation="horizontal">

        <LinearLayout
            android:id="@+id/card_option_c"
            android:layout_width="0dp"
            android:layout_height="64dp"
            android:layout_weight="1"
            android:layout_marginEnd="@dimen/spacing_xs"
            android:background="@drawable/bg_card_white"
            android:gravity="center"
            android:orientation="horizontal"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:background="@drawable/bg_badge_yellow"
                android:gravity="center"
                android:text="C"
                android:textColor="@color/color_text_primary"
                android:textSize="@dimen/text_caption"
                android:textStyle="bold" />

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginStart="@dimen/spacing_md"
                android:background="@drawable/bg_card_yellow_bordered"
                android:src="@drawable/ic_shape_star" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/card_option_d"
            android:layout_width="0dp"
            android:layout_height="64dp"
            android:layout_weight="1"
            android:layout_marginStart="@dimen/spacing_xs"
            android:background="@drawable/bg_card_white"
            android:gravity="center"
            android:orientation="horizontal"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:background="@drawable/bg_badge_yellow"
                android:gravity="center"
                android:text="D"
                android:textColor="@color/color_text_primary"
                android:textSize="@dimen/text_caption"
                android:textStyle="bold" />

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginStart="@dimen/spacing_md"
                android:background="@drawable/bg_card_teal_bordered"
                android:src="@drawable/ic_shape_circle" />
        </LinearLayout>
    </LinearLayout>

    <Space
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Action -->
    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btn_submit"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_marginTop="@dimen/spacing_lg"
        android:background="@drawable/bg_button_disabled"
        android:enabled="false"
        android:text="@string/session_submit"
        android:textColor="#A0A0A0"
        android:textSize="@dimen/text_body"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_sm"
        android:gravity="center"
        android:text="@string/session_choose_one"
        android:textColor="@color/color_text_secondary"
        android:textSize="@dimen/text_caption"
        android:textStyle="bold" />

    <View
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:layout_marginTop="@dimen/spacing_xl"
        android:background="@drawable/bg_divider" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_md"
        android:layout_marginBottom="@dimen/spacing_md"
        android:gravity="center"
        android:text="@string/session_footer"
        android:textColor="@color/color_text_secondary"
        android:textSize="@dimen/text_caption"
        android:textStyle="bold" />

</LinearLayout>
