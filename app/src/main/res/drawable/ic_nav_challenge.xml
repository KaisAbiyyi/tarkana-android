<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Selected state: Box card with border and shadow -->
    <item android:state_checked="true">
        <layer-list>
            <!-- Shadow -->
            <item android:top="4dp" android:left="4dp" android:bottom="0dp" android:right="0dp">
                <shape android:shape="rectangle">
                    <solid android:color="#000000" />
                </shape>
            </item>
            <!-- Card -->
            <item android:top="0dp" android:left="0dp" android:bottom="4dp" android:right="4dp">
                <shape android:shape="rectangle">
                    <solid android:color="#FFFFFF" />
                    <stroke android:width="2dp" android:color="#000000" />
                </shape>
            </item>
            <!-- Icon centered inside card -->
            <item android:top="7dp" android:left="7dp" android:bottom="11dp" android:right="11dp"
                  android:drawable="@drawable/ic_challenge" />
        </layer-list>
    </item>

    <!-- Pressed state -->
    <item android:state_pressed="true">
        <layer-list>
            <!-- Card shifted to cover shadow -->
            <item android:top="4dp" android:left="4dp" android:bottom="0dp" android:right="0dp">
                <shape android:shape="rectangle">
                    <solid android:color="#FFFFFF" />
                    <stroke android:width="2dp" android:color="#000000" />
                </shape>
            </item>
            <!-- Icon shifted with the card -->
            <item android:top="11dp" android:left="11dp" android:bottom="7dp" android:right="7dp"
                  android:drawable="@drawable/ic_challenge" />
        </layer-list>
    </item>

    <!-- Default state: Transparent box to maintain bounds and alignment -->
    <item>
        <layer-list>
            <!-- Outer transparent card spacer -->
            <item android:top="0dp" android:left="0dp" android:bottom="4dp" android:right="4dp">
                <shape android:shape="rectangle">
                    <solid android:color="#00000000" />
                </shape>
            </item>
            <!-- Icon centered -->
            <item android:top="7dp" android:left="7dp" android:bottom="11dp" android:right="11dp"
                  android:drawable="@drawable/ic_challenge" />
        </layer-list>
    </item>
</selector>
