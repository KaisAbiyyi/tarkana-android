<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Pressed state -->
    <item android:state_pressed="true">
        <layer-list>
            <item android:top="4dp" android:left="4dp" android:bottom="0dp" android:right="0dp">
                <shape android:shape="rectangle">
                    <solid android:color="#FFFFFF" />
                    <stroke android:width="2dp" android:color="#000000" />
                </shape>
            </item>
        </layer-list>
    </item>
    <!-- Default state -->
    <item>
        <layer-list>
            <!-- Shadow -->
            <item android:top="4dp" android:left="4dp" android:bottom="0dp" android:right="0dp">
                <shape android:shape="rectangle">
                    <solid android:color="#000000" />
                </shape>
            </item>
            <!-- Card -->
            <item android:top="0dp" android:left="0dp" android:bottom="4dp" android:right="4dp">
                <shape android:shape="rectangle">
                    <solid android:color="#FFFFFF" />
                    <stroke android:width="2dp" android:color="#000000" />
                </shape>
            </item>
        </layer-list>
    </item>
</selector>
